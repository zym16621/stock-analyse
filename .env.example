# ============ 基础 ============
RUN_MODE=prod
PROJECT_NAME=stock-analyse
SERVICE_PORT=8168
LOG_LEVEL=INFO
REGION=hongkong

# ============ 数据源 ============
LIXINGER_TOKEN=请填入你的理杏仁 token

# ============ 微信 dispatch 鉴权 (Node bot 与 Python 共享，建议 32 字节随机串) ============
# 生成方式: openssl rand -hex 32
WECHAT_DISPATCH_TOKEN=请生成一个长随机串

# ============ 数据库/Redis（极简模式默认禁用，无需填写）============
ENABLE_DB=false
ENABLE_REDIS=false
# 仅在 ENABLE_DB=true 时需要：
# DB_HOST=
# DB_PORT=3306
# DB_USER=
# DB_PASSWORD=
# DB_NAME=
# 仅在 ENABLE_REDIS=true 时需要：
# REDIS_HOST=
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ============ Nacos / OSS（默认关闭，按需启用）============
ENABLE_NACOS=False

# ============ docker-compose 镜像配置 ============
DOCKER_REGISTRY=registry.cn-shenzhen.aliyuncs.com/your-namespace
IMAGE_TAG=latest
